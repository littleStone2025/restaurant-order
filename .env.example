# ========== 环境配置示例 ==========
# 复制此文件为 .env 并填写真实值

# 服务器
PORT=3000
NODE_ENV=development

# 数据库（SQLite，无需额外配置）
DB_PATH=./data/restaurant.db

# JWT 密钥（商家后台登录）
JWT_SECRET=change-me-in-production-very-long-random-string

# 微信支付（JSAPI）- 以下为空时请使用模拟支付模式
# 在微信商户平台获取
WX_MCHID=          # 商户号
WX_MCHID=your_mchid
WX_SERIAL_NO=      # 平台证书序列号
WX_PRIVATE_KEY_PATH=./certs/apiclient_key.pem   # 商户私钥路径
WX_PLATFORM_CERT_PATH=./certs/wechatpay_cert.pem # 平台证书路径

# 微信公众号（获取 openid 用）
WX_APPID=your_appid
WX_APPSECRET=your_appsecret

# 微信支付回调地址（必须是外网可访问的 HTTPS 地址）
WX_PAY_NOTIFY_URL=https://your-domain.com/api/pay/callback

# 微信 JSSDK 授权域名（用于生成签名）
WX_JS_DOMAIN=https://your-domain.com

# 前端静态文件目录（生产环境）
STATIC_DIR=./public
